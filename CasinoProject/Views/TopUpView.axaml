<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CasinoProject.ViewModels"
             x:Class="CasinoProject.Views.TopUpView"
             x:DataType="vm:TopUpViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Background" Value="#0f121a"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#1Affffff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement, ComboBox:focus /template/ Border#PART_BorderElement, NumericUpDown:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#f5c518"/> <Setter Property="Background" Value="#0f121a"/>
        </Style>
        
        <Style Selector="Button.ActionBtn">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="0,18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="LetterSpacing" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover">
            <Setter Property="RenderTransform" Value="translateY(-4px)"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        
        <Border Width="450" Background="#161b28" CornerRadius="24" Padding="40" 
                BorderBrush="#1Affffff" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BoxShadow="0 25 50 0 #99000000">
            
            <StackPanel Spacing="18">
                
                <Button Content="✕" Command="{Binding GoBackToMenuCommand}" 
                        Background="Transparent" Foreground="#8b92a5" FontSize="20" FontWeight="Bold"
                        HorizontalAlignment="Right" Margin="0,-20,-20,0" Padding="10"/>

                <TextBlock Text="DEPOSIT FUNDS" FontSize="26" FontWeight="Black" LetterSpacing="1"
                           Foreground="#f5c518" HorizontalAlignment="Center" Margin="0,-10,0,10"/>

                <TextBlock Text="SELECT METHOD" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                <ComboBox ItemsSource="{Binding PaymentMethods}" 
                          SelectedItem="{Binding SelectedMethod}" 
                          IsEnabled="{Binding !IsProcessing}"
                          HorizontalAlignment="Stretch"/>

                <StackPanel Spacing="15" IsVisible="{Binding IsBlikVisible}">
                    <TextBlock Text="BLIK CODE (6 DIGITS)" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                    <TextBox Text="{Binding BlikCode}" PlaceholderText="123456" 
                             IsEnabled="{Binding !IsProcessing}" MaxLength="6"/>
                </StackPanel>

                <StackPanel Spacing="15" IsVisible="{Binding IsCardVisible}">
                    <TextBlock Text="CARD NUMBER" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                    <TextBox Text="{Binding CardNumber}" PlaceholderText="0000 0000 0000 0000" IsEnabled="{Binding !IsProcessing}"/>
                    
                    <Grid ColumnDefinitions="*, 15, *">
                        <StackPanel Grid.Column="0" Spacing="15">
                            <TextBlock Text="EXPIRY (MM/YY)" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                            <TextBox Text="{Binding CardExpiry}" PlaceholderText="MM/YY" IsEnabled="{Binding !IsProcessing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="15">
                            <TextBlock Text="CVV" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                            <TextBox Text="{Binding CardCvv}" PlaceholderText="123" PasswordChar="*" MaxLength="3" IsEnabled="{Binding !IsProcessing}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="15" IsVisible="{Binding IsCryptoVisible}">
                    <TextBlock Text="DESTINATION WALLET" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,-10"/>
                    <TextBox Text="{Binding CryptoAddress}" PlaceholderText="0x123abc..." IsEnabled="{Binding !IsProcessing}"/>
                </StackPanel>

                <TextBlock Text="AMOUNT (USD)" Foreground="#8b92a5" FontSize="11" FontWeight="Bold" LetterSpacing="1" Margin="0,10,0,-10"/>
                <NumericUpDown Value="{Binding Amount}" Minimum="1" Maximum="10000" 
                               IsEnabled="{Binding !IsProcessing}" 
                               Height="50" FontSize="18" FontWeight="Bold"/>

                <Button Classes="ActionBtn" Content="COMPLETE DEPOSIT" Command="{Binding ProcessPaymentCommand}" 
                        Margin="0,15,0,0" IsEnabled="{Binding !IsProcessing}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#ff8a00" Offset="0"/>
                            <GradientStop Color="#f5c518" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#f5c518" 
                           FontWeight="SemiBold" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                
            </StackPanel>
        </Border>
    </Grid>
</UserControl>